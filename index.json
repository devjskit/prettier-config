{
  "$schema": "http://json.schemastore.org/prettierrc",
  "plugins": ["prettier-plugin-organize-imports"],
  "arrowParens": "always",
  "bracketSpacing": true,
  "cursorOffset": -1,
  "insertPragma": false,
  "printWidth": 160,
  "proseWrap": "preserve",
  "requirePragma": false,
  "singleQuote": false,
  "useTabs": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "semi": true,
  "overrides": [
    {
      "files": "*.ts",
      "options": { "parser": "typescript" }
    }
  ]
}
